# Anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001

# X (Twitter)
# auth_token cookie value from your browser session at x.com
X_AUTH_TOKEN=
# Run Playwright in headed mode (true) or headless (false)
X_HEADLESS=false

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=twitter

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Monitoring
MONITOR_INTERVAL_SECONDS=120

# Tweet character limit. 280 for free X accounts, 25000 for X Premium.
TWEET_CHAR_LIMIT=280

# Local autoreply server (called by Chrome extension)
AUTOREPLY_HOST=127.0.0.1
AUTOREPLY_PORT=8765

# Logging
LOG_LEVEL=INFO
